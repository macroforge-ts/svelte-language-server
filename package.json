{
  "author": "macroforge contributors",
  "bin": {
    "svelteserver": "bin/server.js"
  },
  "bugs": {
    "url": "https://github.com/macroforge-ts/svelte-language-server/issues"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "@macroforge/typescript-plugin": "^0.1.74",
    "@vscode/emmet-helper": "2.8.4",
    "chokidar": "^4.0.1",
    "estree-walker": "^2.0.1",
    "fdir": "^6.2.0",
    "globrex": "^0.1.2",
    "lodash": "^4.17.21",
    "macroforge": "^0.1.74",
    "prettier": "~3.3.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^4.2.19",
    "svelte2tsx": "^0.7.45",
    "typescript": "^5.9.2",
    "typescript-auto-import-cache": "^0.3.6",
    "vscode-css-languageservice": "~6.3.5",
    "vscode-html-languageservice": "~5.4.0",
    "vscode-languageserver": "9.0.1",
    "vscode-languageserver-protocol": "3.17.5",
    "vscode-languageserver-types": "3.17.5",
    "vscode-uri": "~3.1.0"
  },
  "description": "A language server for Svelte with macroforge integration",
  "devDependencies": {
    "@types/estree": "^0.0.42",
    "@types/globrex": "^0.1.4",
    "@types/lodash": "^4.14.116",
    "@types/mocha": "^9.1.0",
    "@types/node": "^18.0.0",
    "@types/sinon": "^7.5.2",
    "cross-env": "^7.0.2",
    "mocha": "^9.2.0",
    "sinon": "^11.0.0",
    "ts-node": "^10.0.0"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./bin/server.js": "./bin/server.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin"
  ],
  "homepage": "https://github.com/macroforge-ts/svelte-language-server#readme",
  "keywords": [
    "svelte",
    "vscode",
    "language-server",
    "macroforge"
  ],
  "license": "MIT",
  "main": "dist/src/index.js",
  "name": "@macroforge/svelte-language-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macroforge-ts/svelte-language-server.git"
  },
  "scripts": {
    "build": "deno task clean && deno install --node-modules-dir --quiet && deno run -A npm:typescript@5/tsc",
    "clean": "rm -rf dist",
    "cleanbuild": "deno task clean && deno task build",
    "pretest": "node test/setup-fixtures.js",
    "test": "cross-env TS_NODE_TRANSPILE_ONLY=true mocha --require ts-node/register \"test/**/*.test.ts\" --no-experimental-strip-types",
    "watch": "deno run -A npm:typescript@5/tsc -w"
  },
  "typings": "dist/src/index",
  "version": "0.1.74"
}
